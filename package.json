{
  "name": "iris-code",
  "version": "0.1.0",
  "description": "IRIS — a radial, self-clocking 2D optical code (the successor experiment to QR). Zero-dependency reference implementation.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./pixi": "./src/pixi-render.js",
